# --- Postgres ---
POSTGRES_USER=doings
POSTGRES_PASSWORD=doings
POSTGRES_DB=doings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Async URL used by app + alembic
DATABASE_URL=postgresql+asyncpg://doings:doings@postgres:5432/doings
# Sync URL for alembic if needed
DATABASE_URL_SYNC=postgresql+psycopg://doings:doings@postgres:5432/doings

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-me-in-prod-please-32+chars-please-change
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost

# --- Telegram bots (get tokens from @BotFather) ---
TG_DOERS_BOT_TOKEN=
TG_CUSTOMERS_BOT_TOKEN=
TG_REFEREE_BOT_TOKEN=

# Public URL of the Mini App (HTTPS in prod)
TG_WEBAPP_URL=http://localhost

# Frontend
VITE_API_BASE_URL=/api/v1
